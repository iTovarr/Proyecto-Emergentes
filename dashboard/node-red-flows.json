        "name": "function 18",
        "func": "// Function 18: envía alerta por WhatsApp cuando se detecta humo\nif (msg.payload && Array.isArray(msg.payload) && msg.payload.length > 0) {\n    let ultimo = msg.payload[0];\n    let valor = ultimo.valor_humo;\n\n    if (valor > 0) {\n        // Mensaje de alerta\n        msg.payload = \"🚨 Alerta: Se ha detectado humo en el área. Valor: \" + valor;\n        return msg;\n    } else {\n        // No hay humo, no enviar mensaje\n        return null;\n    }\n} else {\n    node.warn(\"⚠️ No se encontraron datos válidos en la consulta MySQL\");\n    return null;\n}\n",
