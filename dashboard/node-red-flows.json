    {
        "id": "4a037ace9511cf49",
        "type": "function",
        "z": "b3369ac659491d3f",
        "name": "function 21",
        "func": "// Function 21: enviar mensaje al tópico Sistema/Humedad\n// Se ejecuta cuando se guarda un nuevo dato de humedad\n\nif (msg.payload && Array.isArray(msg.payload) && msg.payload.length > 0) {\n    // Tomar el último registro del resultado MySQL\n    let ultimo = msg.payload[msg.payload.length - 1];\n    let valor = ultimo.valor_humedad;\n\n    // Evaluar el valor de humedad\n    if (valor > 0) {\n        msg.topic = \"Sistema/Humedad\";\n        msg.payload = \"Techo_Activado\";\n        node.warn(\"🌧️ Humedad detectada (\" + valor + \"), techo activado\");\n    } else {\n        msg.topic = \"Sistema/Humedad\";\n        msg.payload = \"Techo_Desactivado\";\n        node.warn(\"🌤️ Sin humedad (\" + valor + \"), techo desactivado\");\n    }\n\n    return msg;\n} else {\n    // Si no hay datos válidos, enviar desactivado\n    msg.topic = \"Sistema/Humedad\";\n    msg.payload = \"Techo_Desactivado\";\n    node.warn(\"⚠️ No se encontraron datos válidos, se envía desactivado\");\n    return msg;\n}\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1350,
        "y": 480,
        "wires": [
