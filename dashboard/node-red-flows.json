    {
        "id": "0488365ad5427d12",
        "type": "function",
        "z": "b3369ac659491d3f",
        "name": "function 4",
        "func": "// Function 4: recibe dato del tópico MQTT Sensor_de_Agua y prepara para MySQL y dashboard\nlet data = msg.payload;\n\n// Si el mensaje llega como objeto con la propiedad valor_agua\nif (data && typeof data === \"object\" && data.valor_agua !== undefined) {\n    let valor = data.valor_agua;\n\n    // Inserción en MySQL con parámetros nombrados\n    let insertMsg = {\n        topic: \"INSERT INTO Registro_Humedad (valor_humedad) VALUES (:valor_humedad)\",\n        payload: {\n            valor_humedad: valor\n        }\n    };\n\n    // Fila para mostrar en el dashboard\n    let filaMsg = {\n        payload: [{\n            orden: \"-\", // MySQL asignará el número real\n            valor_humedad: valor\n        }]\n    };\n\n    // Salida 1 → MySQL, Salida 2 → ui_table\n    return [insertMsg, filaMsg];\n} else {\n    node.warn(\"⚠️ Payload inválido: se esperaba un objeto con valor_agua\");\n    return null;\n}\n\n\n",
