        ]
    },
    {
        "id": "e2a4688ba4848bb5",
        "type": "function",
        "z": "b3369ac659491d3f",
        "name": "function 22",
        "func": "// Function 22: registra intentos de acceso denegado\nlet data = msg.payload;\n\n// Verificar si faltan datos o el formato es incorrecto\nif (!data || !data.numero_id || !data.hora || !data.fecha) {\n    // Incrementar contador local para orden\n    context.set(\"contador\", context.get(\"contador\") || 0);\n    let orden = context.get(\"contador\") + 1;\n    context.set(\"contador\", orden);\n\n    // Obtener fecha y hora actual\n    let ahora = new Date();\n    let fecha = ahora.toISOString().split(\"T\")[0];\n    let hora = ahora.toTimeString().split(\" \")[0];\n    let mensaje = \"Intento de acceso denegado\";\n\n    // Mensaje para MySQL (usa parámetros nombrados)\n    let insertMsg = {\n        topic: \"INSERT INTO Registro_Fallas (fecha, hora, mensaje) VALUES (:fecha, :hora, :mensaje)\",\n        payload: {\n            fecha: fecha,\n            hora: hora,\n            mensaje: mensaje\n        }\n    };\n\n    // Mensaje para dashboard\n    let filaMsg = {\n        payload: [{\n            orden: orden,\n            fecha: fecha,\n            hora: hora,\n            mensaje: mensaje\n        }]\n    };\n\n    // Salida 1 → MySQL, Salida 2 → ui_table\n    return [insertMsg, filaMsg];\n} else {\n    // Si los datos son válidos, no registrar aquí\n    return null;\n}\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 490,
        "y": 240,
