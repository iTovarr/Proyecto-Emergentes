        "name": "function 3",
        "func": "// Function 3: recibe los resultados del MySQL y los imprime en el cuadro\nif (msg.payload && Array.isArray(msg.payload)) {\n    msg.payload = msg.payload.map(row => ({\n        id: row.id,              // usar id en vez de orden\n        numero_id: row.numero_id,\n        hora: row.hora,\n        fecha: row.fecha\n    }));\n    return msg;\n} else {\n    node.warn(\"⚠️ No se recibieron datos válidos desde MySQL\");\n    return null;\n}\n",
