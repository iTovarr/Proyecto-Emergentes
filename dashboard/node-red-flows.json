    {
        "id": "e237a2dc738a0240",
        "type": "function",
        "z": "b3369ac659491d3f",
        "name": "function 20",
        "func": "// Function 20: enviar mensaje al tópico Sistema/Puerta\n// Se ejecuta cuando se guarda un nuevo registro de huella\n\nlet nuevoDato = msg.payload; // datos del registro recién insertado\nlet mensaje = \"Puerta_Abierta\"; // palabra que Arduino espera\n\n// Publicar al tópico MQTT\nmsg.topic = \"Sistema/Puerta\";\nmsg.payload = mensaje;\n\nnode.warn(\"🚪 Nuevo registro detectado, puerta abierta\");\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
