    {
        "id": "ff01089a62ec8c13",
        "type": "function",
        "z": "b3369ac659491d3f",
        "name": "function 1",
        "func": "// Function 1: recibe datos del tópico MQTT y prepara para MySQL y dashboard\nlet data = msg.payload;\n\nif (data.numero_id && data.hora && data.fecha) {\n    // Inserción en MySQL con parámetros nombrados\n    let insertMsg = {\n        topic: \"INSERT INTO Registro_Ingreso (numero_id, hora, fecha) VALUES (:numero_id, :hora, :fecha)\",\n        payload: {\n            numero_id: data.numero_id,\n            hora: data.hora,\n            fecha: data.fecha\n        }\n    };\n\n    // Fila para mostrar en el dashboard (usando id como identificador)\n    let filaMsg = {\n        payload: [{\n            id: \"-\", // MySQL asignará el valor real automáticamente\n            numero_id: data.numero_id,\n            hora: data.hora,\n            fecha: data.fecha\n        }]\n    };\n\n    // Salida 1 → MySQL, Salida 2 → ui_table\n    return [insertMsg, filaMsg];\n} else {\n    node.warn(\"⚠️ Datos incompletos en el payload MQTT\");\n    return null;\n}\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
